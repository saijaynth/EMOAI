# ============================================================================
# Emo AI Backend Configuration
# ============================================================================

# Backend Server
APP_NAME=Emo AI API
APP_ENV=development
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
DEBUG=false

# ============================================================================
# AI / LLM (Required for high-accuracy mood detection)
# ============================================================================
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Music APIs (Optional — enables live globally-best song recommendations)
# ============================================================================

# --- Spotify (RECOMMENDED — Best accuracy + audio features) ---
# 1. Go to: https://developer.spotify.com/dashboard
# 2. Click "Create App"
# 3. App Name: "Emo AI Dev"
# 4. Redirect URI: http://localhost:3000
# 5. Copy Client ID and Client Secret below
# 6. No Premium account needed for API access (Premium only needed for Web Playback SDK)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# --- Last.fm (Fallback when Spotify unavailable) ---
# Get your key: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# ============================================================================
# Frontend
# ============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
